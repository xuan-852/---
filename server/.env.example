# 云服务器配置
PORT=3000

# 服务端口
PORT=3000

# 小程序认证 Token（API 鉴权用）
MINI_TOKEN=your_mini_token_here

# 桌面端认证 Token
DESKTOP_TOKEN=your_desktop_token_here

# 加密密钥（≥32 字符，用于加密存储的教务密码）
ENCRYPTION_KEY=your-32-char-encryption-key-here!!!!

# BKJW 桥接服务地址
BRIDGE_URL=http://localhost:3456

# 桥接服务 Token——bkjw_bridge.js 启动时自动生成的 Token
BRIDGE_TOKEN=your_bridge_token_here

# Bridge 自动重登凭据 Token——Bridge 用此 Token 向主服务请求教务密码
BRIDGE_CRED_TOKEN=your_bridge_cred_token_here

# 公网地址（小程序动态配置用，如 ngrok）
PUBLIC_URL=https://your-domain.ngrok-free.dev
