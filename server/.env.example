# 云服务器配置
PORT=3000

# 桌面端认证 Token
DESKTOP_TOKEN=your_desktop_token_here

# 小程序认证 Token
MINI_TOKEN=your_mini_token_here

# BKJW 桥接服务访问地址（持久化浏览器）
BRIDGE_URL=http://localhost:3456
# 桥接服务 Token——由 bkjw_bridge.js 启动时自动生成
BRIDGE_TOKEN=your_bridge_token_here

# Bridge 自动重登凭据 Token（Plan A 用）
# 需与 .env 中的值一致，供 Bridge 向主服务器请求教务密码
BRIDGE_CRED_TOKEN=your_bridge_cred_token_here

# 公网地址（小程序端动态配置用）
PUBLIC_URL=https://your-domain.ngrok-free.dev
