.container {
  min-height: 100vh;
  background: #0f0f23;
  color: #e0e0e0;
  padding: 20rpx 30rpx;
}

.offline-tip {
  background: rgba(255, 138, 101, 0.15);
  color: #ff8a65;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.gpa-card {
  background: linear-gradient(135deg, #7c4dff, #448aff);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.gpa-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}

.gpa-value {
  font-size: 72rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-top: 10rpx;
}

.gpa-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-top: 8rpx;
}

/* 学期组 */
.semester-group {
  margin-bottom: 16rpx;
}

.semester-header {
  background: #1e1e42;
  border-radius: 14rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.semester-left {
  flex: 1;
}

.semester-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.semester-meta {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}

.semester-arrow {
  font-size: 24rpx;
  color: #666;
  transition: transform 0.2s;
}

.semester-arrow.active {
  transform: rotate(90deg);
  color: #7c4dff;
}

/* 成绩列表 */
.score-list {
  padding: 8rpx 0 0 0;
}

.score-card {
  background: #1a1a3e;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 6rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-name {
  font-size: 28rpx;
  color: #e0e0e0;
  display: block;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
}

.score-value.pass { color: #4caf50; }
.score-value.fail { color: #f44336; }

.score-credit {
  font-size: 22rpx;
  color: #666;
  display: block;
  text-align: right;
}
