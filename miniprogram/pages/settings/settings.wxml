<view class="container">
  <!-- 连接状态 -->
  <view wx:if="{{!connected}}" class="offline-banner">🔴 未连上服务器 · 后端不在线</view>

  <!-- 绑定状态 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">🔗 账号绑定状态</text>
    </view>
    <view wx:if="{{loadingStatus}}" class="loading-row">
      <text>检查中...</text>
    </view>
    <view wx:else>
      <view wx:if="{{bound}}" class="status-badge bound">
        <text>✅ 已绑定 — {{username}}</text>
      </view>
      <view wx:else class="status-badge unbound">
        <text>❌ 未绑定</text>
      </view>
    </view>
    <!-- 诊断信息：仅出错时显示 -->
    <view wx:if="{{statusError}}" class="status-error">
      <text>{{statusError}}</text>
    </view>
    <!-- 服务器地址 -->
    <view class="server-info">
      <text>服务器：{{serverUrl}}</text>
    </view>
    <!-- 跳过缓存的强制检查按钮 -->
    <button class="btn-diag" bindtap="onCheckConnection" size="mini">🔍 强制检查绑定状态（跳过缓存）</button>
  </view>

  <!-- 绑定表单 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">📋 绑定教务账号</text>
    </view>
    <view class="form">
      <input class="input" placeholder="学号" value="{{studentId}}" bindinput="onIdInput" />
      <input class="input" placeholder="密码" password="{{!showPwd}}" value="{{password}}" bindinput="onPwdInput" />
      <view class="form-options">
        <label class="checkbox-label">
          <checkbox checked="{{showPwd}}" bindchange="togglePwd" /> 显示密码
        </label>
      </view>
      <button class="btn-primary" bindtap="onBind" disabled="{{!studentId || !password || binding}}">
        {{binding ? '绑定中...' : '保存并绑定'}}
      </button>
    </view>
  </view>

  <!-- 数据操作 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">🔄 数据操作</text>
    </view>
    <button class="btn-secondary" bindtap="onRefresh" disabled="{{refreshing}}">
      {{refreshing ? '刷新中...' : '🔄 手动刷新数据'}}
    </button>
    <view class="tip">将从教务系统同步最新课表、成绩和考试安排。</view>
  </view>

  <!-- 关于 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">ℹ️ 关于</text>
    </view>
    <text class="about-text">
      南理工课表助手通过后端代理访问教务系统。
      你的学号和密码仅用于登录教务系统获取数据，
      经过加密存储，不会明文传输。
    </text>
  </view>
</view>
