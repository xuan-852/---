.container {
  min-height: 100vh;
  background: #0f0f23;
  color: #e0e0e0;
  padding: 20rpx 30rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.date {
  font-size: 36rpx;
  color: #7c4dff;
  font-weight: bold;
}

.week {
  display: block;
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
}

.section {
  margin: 30rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  display: block;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #666;
  font-size: 32rpx;
}

.course-card {
  background: linear-gradient(135deg, #1a1a3e, #2a1a4e);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  border-left: 6rpx solid #7c4dff;
}

.course-time {
  font-size: 24rpx;
  color: #7c4dff;
  min-width: 140rpx;
}

.course-info {
  flex: 1;
  margin: 0 20rpx;
}

.course-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.course-location {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-top: 6rpx;
}

.course-slot {
  font-size: 22rpx;
  color: #666;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
  padding: 20rpx 0;
}

.action-btn {
  background: #1a1a3e;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  color: #e0e0e0;
  font-size: 26rpx;
}
