<view class="container">
  <view class="section">
    <text class="section-title">📝 考试安排</text>
    <view wx:if="{{exams.length === 0}}" class="empty">
      <text>暂无考试安排~</text>
    </view>
    <view wx:for="{{exams}}" wx:key="id" class="exam-card">
      <text class="exam-title">{{item.title}}</text>
      <text class="exam-body">{{item.body}}</text>
    </view>
  </view>
</view>
