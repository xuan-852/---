.container {
  min-height: 100vh;
  background: #0f0f23;
  color: #e0e0e0;
  padding: 20rpx 30rpx;
}

.offline-tip {
  background: rgba(255, 138, 101, 0.15);
  color: #ff8a65;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  display: block;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #666;
  font-size: 28rpx;
}

.exam-card {
  background: #1a1a3e;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 14rpx;
  border-left: 6rpx solid #ff6b6b;
}

.exam-title {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.exam-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.exam-label {
  font-size: 24rpx;
  color: #888;
  width: 140rpx;
  flex-shrink: 0;
}

.exam-value {
  font-size: 26rpx;
  color: #e0e0e0;
}
