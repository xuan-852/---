<view class="container">
  <!-- 连接状态 -->
  <view wx:if="{{!connected}}" class="offline-tip">🔴 未连上服务器 · 显示缓存数据</view>
  <view class="schedule-sub">
    <text class="semester-label">{{semester}}</text>
    <text class="week-range">1 - {{maxWeek}} 周</text>
  </view>

  <!-- 周选择器 -->
  <view class="week-picker">
    <view class="arrow" bindtap="prevWeek">‹</view>
    <text class="week-label">第 {{currentWeek}} 周</text>
    <view class="arrow" bindtap="nextWeek">›</view>
  </view>

  <!-- 课表网格 -->
  <scroll-view scroll-x class="schedule-scroll">
    <view class="schedule-grid">
      <view wx:for="{{days}}" wx:key="*this" class="day-column">
        <view class="day-header">{{item}}</view>
        <view wx:for="{{scheduleData[index] || []}}" wx:key="id" class="mini-course">
          <text class="mini-name">{{item.name}}</text>
          <text class="mini-time">{{item.start_time}}</text>
          <text class="mini-location">{{item.location}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
