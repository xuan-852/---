<view class="container" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <!-- 连接状态 -->
  <view wx:if="{{!connected}}" class="offline-tip">🔴 离线模式 · 显示缓存数据</view>

  <!-- 顶部：学期 + 周信息 -->
  <view class="schedule-top">
    <view class="semester-label">{{semester}}</view>
    <view class="range-label">第 {{currentWeek}} 周 / {{maxWeek}} 周</view>
  </view>

  <!-- 课表网格 -->
  <view class="schedule-grid">
    <!-- 表头行：星期 -->
    <view class="grid-row grid-header">
      <view class="cell time-cell"></view>
      <view wx:for="{{days}}" wx:if="{{item}}" wx:key="*this" class="cell day-cell">{{item}}</view>
    </view>
    <!-- 12 节次行 -->
    <view wx:for="{{12}}" wx:key="*this" class="grid-row">
      <view class="cell time-cell">
        <text class="slot-num">{{slots[index]}}</text>
        <text class="slot-time">{{slotTimes[index]}}</text>
      </view>
      <view wx:for="{{7}}" wx:key="*this" class="cell slot-cell"></view>
    </view>

    <!-- 课程卡片（绝对定位在网格容器内） -->
    <view wx:for="{{cards}}" wx:key="id" class="course-tile"
      style="left: {{item.left}}rpx; top: {{item.top}}rpx; width: {{item.width}}rpx; height: {{item.height}}rpx; background: {{item.bg}}; border-color: {{item.border}};">
      <text class="tile-name" style="color: {{item.textColor}};">{{item.name}}</text>
      <text wx:if="{{item.location}}" class="tile-location">{{item.location}}</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!hasCache && cards.length === 0}}" class="empty-state">
    <text class="empty-icon">📅</text>
    <text class="empty-text">暂无课表数据，请先绑定并刷新</text>
  </view>

  <!-- 底部周导航 -->
  <view class="week-nav">
    <view class="nav-btn" bindtap="prevWeek">‹ 上一周</view>
    <view class="nav-current">第 {{currentWeek}} 周</view>
    <view class="nav-btn" bindtap="nextWeek">下一周 ›</view>
  </view>
</view>
