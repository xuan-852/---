.container {
  min-height: 100vh;
  background: #0f0f23;
  color: #e0e0e0;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.offline-tip {
  background: rgba(255, 138, 101, 0.15);
  color: #ff8a65;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  text-align: center;
  margin-bottom: 6rpx;
}

/* 顶部信息 */
.schedule-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx;
  margin-bottom: 6rpx;
}
.semester-label { font-size: 22rpx; color: #888; }
.range-label { font-size: 20rpx; color: #666; }

/* ===== 课表网格 ===== */
.schedule-grid {
  position: relative;
  /* 高度：header 44rpx + 12行 * 78rpx = 980rpx */
  height: 980rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 8rpx;
  background: rgba(255,255,255,0.01);
}

/* 行 */
.grid-row {
  display: flex;
  height: 78rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.grid-header {
  height: 44rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  position: sticky;
  top: 0;
  z-index: 3;
  background: #0f0f23;
}

/* 通用格子 */
.cell {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 节次列（左侧固定 70rpx） */
.time-cell {
  width: 70rpx;
  min-width: 70rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0f0f23;
  position: sticky;
  left: 0;
  z-index: 2;
}
.grid-header .time-cell {
  font-size: 18rpx;
  color: #555;
}

.slot-num {
  font-size: 20rpx;
  color: #666;
  font-weight: bold;
  line-height: 1.2;
}
.slot-time {
  font-size: 16rpx;
  color: #444;
  line-height: 1.2;
}

/* 日期列头 */
.day-cell {
  flex: 1;
  font-size: 22rpx;
  color: #999;
  font-weight: bold;
}

/* 节次占位格子 */
.slot-cell {
  flex: 1;
  height: 100%;
  background: transparent;
  border-right: 1rpx solid rgba(255,255,255,0.03);
}
.slot-cell:last-child {
  border-right: none;
}
.grid-row:nth-child(odd) .slot-cell {
  background: rgba(255,255,255,0.015);
}

/* 课程卡片 */
.course-tile {
  position: absolute;
  border-radius: 6rpx;
  border-left: 4rpx solid;
  padding: 4rpx 6rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  z-index: 1;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3);
  box-sizing: border-box;
}

.tile-name {
  font-size: 20rpx;
  font-weight: bold;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.tile-location {
  font-size: 16rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部周导航 */
.week-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
  gap: 24rpx;
}
.nav-btn {
  font-size: 26rpx;
  color: #7c4dff;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(124, 77, 255, 0.3);
  border-radius: 12rpx;
}
.nav-btn:active {
  background: rgba(124, 77, 255, 0.1);
}
.nav-current {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  min-width: 120rpx;
  text-align: center;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}
.empty-icon { font-size: 56rpx; display: block; }
.empty-text { color: #666; font-size: 24rpx; margin-top: 12rpx; display: block; }
